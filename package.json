{
  "private": true,
  "license": "Apache-2.0",
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stoplightio/prism.git"
  },
  "scripts": {
    "lint": "eslint ./packages/**/src/*.ts",
    "lint.fix": "yarn lint --fix",
    "clean": "rm -rf ./packages/**/dist ./packages/**/*.tsbuildinfo",
    "build": "npm run clean && tsc --build --verbose ./packages/tsconfig.build.json",
    "posttest": "yarn lint",
    "test": "node --expose-gc ./node_modules/.bin/jest",
    "release": "lerna version",
    "prebuild.binary": "yarn build",
    "build.binary": "npx @yao-pkg/pkg --output ./cli-binaries/prism-cli --options max_old_space_size=4096 ./packages/cli/",
    "test.harness": "jest -c ./jest.harness.config.js"
  },
  "resolutions": {
    "sanitize-html": "2.12.1",
    "jsonpath-plus": "10.3.0",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@stoplight/types": "^14.1.1",
    "@types/caseless": "^0.12.2",
    "@types/content-type": "^1.1.5",
    "@types/jest": "^30.0.0",
    "@types/json-schema": "^7.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pino": "6.3.12",
    "@types/postman-collection": "^3.5.7",
    "@types/raw-body": "^2.3.0",
    "@types/seedrandom": "^3.0.8",
    "@types/signale": "^1.4.2",
    "@types/split2": "^4.2.3",
    "@types/type-is": "^1.6.3",
    "@types/uri-template-lite": "^19.12.1",
    "@types/urijs": "^1.19.17",
    "@types/whatwg-mimetype": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "abstract-logging": "^2.0.1",
    "diff-js-xml": "^1.0.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-xml-parser": "^5.5.7",
    "form-data": "^4.0.0",
    "gavel": "10.0.3",
    "glob": "^7.2.0",
    "http-string-parser": "^0.0.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lerna": "^9.0.7",
    "lint-staged": "^10.5.4",
    "lodash": "^4.17.23",
    "nock": "^13.1.3",
    "node-fetch": "^2.6.7",
    "prettier": "^3.8.1",
    "split2": "^4.2.0",
    "tmp": "^0.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^9.1.1",
    "ts-transform-import-path-rewrite": "^0.3.0",
    "tsconfig-paths": "^4.1.0",
    "ttypescript": "^1.5.15",
    "type-is": "^1.6.18",
    "typescript": "5.4.5",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "**/packages/**/*.ts": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
